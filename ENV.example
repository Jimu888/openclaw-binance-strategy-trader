# Copy to your system environment variables (recommended)
# Windows PowerShell (temporary for current terminal):
#   $env:BINANCE_API_KEY="..."
#   $env:BINANCE_SECRET_KEY="..."
# Windows (persist):
#   setx BINANCE_API_KEY "..."
#   setx BINANCE_SECRET_KEY "..."

# Required
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Optional
# Binance base URL (default: https://api.binance.com)
# BINANCE_BASE_URL=https://api.binance.com

# Local order server port (default: 3001)
# PORT=3001
